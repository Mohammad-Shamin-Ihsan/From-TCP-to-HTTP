package request

import ("io")

type Request struct {
        RequestLine RequestLine
}

type RequestLine struct {
        HttpVersion   string
        RequestTarget string
        Method        string
}

func RequestFromReader(reader io.Reader) (*Request, error) {
        data, err := io.ReadAll(reader)
        if err != nil {
            return nil, err
        }
        return nil, nil

}
